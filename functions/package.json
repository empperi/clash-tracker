{
  "name": "@clash-tracker/functions",
  "version": "0.1.0",
  "private": true,
  "description": "Firebase Cloud Functions — CoC API gateway, war ingestion, auth, Firestore repositories.",
  "type": "module",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild lib/index.js --bundle --platform=node --target=node22 --outfile=lib/index.js --allow-overwrite --format=esm --external:firebase-admin --external:firebase-functions",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "node scripts/deploy-functions.js",
    "lint": "eslint . --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clash-tracker/core": "*",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1"
  }
}
