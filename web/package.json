    "lint": "eslint . --no-error-on-unmatched-pattern",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@clash-tracker/core": "*",
    "@tanstack/vue-query": "^5.101.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "vite": "^8.0.16"
  }
}
