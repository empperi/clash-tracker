# Web app environment (Vite). Copy to `web/.env.local` for overrides — but you do NOT need
# any of this for local development: `npm run dev` defaults to the Firebase emulators with
# safe demo placeholders, so the app runs with zero setup (run `npm run emulators` too).
#
# These VITE_FIREBASE_* values are the Firebase *web* config. They are PUBLIC (the web
# apiKey identifies the project; it does not grant access — security is enforced by Firestore
# Rules / App Check). So they are NOT secrets: they may be set as plain build-time env / CI
# variables, and must be present when `npm run build` runs for a PRODUCTION deploy.
#
# Vite only exposes vars prefixed with VITE_ to the client, and inlines them at build time.

# Force emulators on/off. Unset = emulators in dev, real config in production builds.
VITE_USE_EMULATORS=true

# Real Firebase web config (from Firebase console → Project settings → Your apps).
# Required for production builds; ignored when using emulators.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
