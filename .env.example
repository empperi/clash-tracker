# Copy to .env (which is gitignored) for local emulator development.
# In production these are set as Cloud Functions secrets / environment variables,
# NOT committed anywhere.

# 32-byte key (base64) used to AES-256-GCM encrypt the CoC API token at rest.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CLASH_TOKEN_ENC_KEY=

# Base URL the CoC API gateway calls. Decision deferred (see tech-stack.md):
#   * Direct:      https://api.clashofclans.com/v1
#   * Via proxy:   https://proxy.royaleapi.dev/v1   (whitelist the proxy's static IP)
COC_API_BASE_URL=https://api.clashofclans.com/v1

# Point the web app + functions at local emulators during development.
VITE_USE_EMULATORS=true
